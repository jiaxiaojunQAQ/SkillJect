# =============================================================================
# SkillJect Environment Configuration
# =============================================================================
# Copy to .env and fill in the values you need:  cp .env.example .env
# run.py auto-loads .env on start. NEVER put real secrets in this example file.
#
# Loading semantics (run.py load_env_file):
#   - Lookup order: project root .env first, then $PWD/.env; first match wins.
#   - Values in .env OVERRIDE variables already exported in your shell, so
#     editing .env always takes effect (no need to unset stale exports).
#   - The loaded .env path is printed at startup. Missing required credentials
#     fail fast with an error naming the exact variable to set.
#
# You only need credentials for the profiles you enable in config/main.yaml
# (execution_plan) plus the Judge LLM (if llm_judge is configured).
# The env var NAMES below come from config/providers/*.yaml (auth_token_env /
# base_url_env) and config/main.yaml (llm_judge.api_key_env / base_url_env).
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Judge LLM  (response classification + optional attack judgment)
# -----------------------------------------------------------------------------
# Names set in config/main.yaml -> llm_judge.{api_key_env, base_url_env}.
# Required when llm_judge is configured (it is, by default). OpenAI-compatible.
JUDGE_LLM_API_KEY=sk-your-judge-api-key-here
# Optional: leave unset to use OpenAI default (https://api.openai.com/v1)
# JUDGE_LLM_BASE_URL=https://api.openai.com/v1


# -----------------------------------------------------------------------------
# 2. Strategy LLM  (test-case / attack payload generation)
# -----------------------------------------------------------------------------
# Names set in config/providers/strategy-llm.yaml. OpenAI-compatible SDK.
# Required only for generation methods that call the LLM (skillject,
# template_injection). NOT needed for method: baseline / direct_execution.
STRATEGY_LLM_API_KEY=sk-your-strategy-api-key-here
# Optional: switch provider via the base URL. Defaults to OpenAI.
#   MiniMax: https://api.minimax.chat/v1
#   Zhipu:   https://open.bigmodel.cn/api/paas/v4
# STRATEGY_LLM_BASE_URL=https://api.openai.com/v1


# -----------------------------------------------------------------------------
# 3. Agent Runtime Credentials  (the agent under test)
# -----------------------------------------------------------------------------
# Fill ONLY the rows matching the profiles you enable in config/main.yaml.
# API keys are shared across agent types; base-URL var names differ per agent.

# --- Claude Code profiles ---------------------------------------------------
# claude-claude  (Anthropic official API)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# claude-gpt  (Claude Code backed by OpenAI)
OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# claude-glm  (Zhipu)
# ZHIPU_API_KEY=your-zhipu-api-key
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/anthropic

# claude-minimax
# MINIMAX_API_KEY=your-minimax-api-key
# CLAUDE_CODE_MINIMAX_BASE_URL=https://api.minimax.chat/anthropic

# claude-mimo  (Anthropic-compatible API)
# MIMO_API_KEY=your-mimo-api-key
# MIMO_BASE_URL=https://your-mimo-endpoint/v1

# --- OpenClaw profiles ------------------------------------------------------
# Required for ANY openclaw-* profile (gateway auth). Use TOKEN or PASSWORD.
# OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token
# OPENCLAW_GATEWAY_PASSWORD=your-openclaw-gateway-password

# openclaw-claude  (Anthropic API) — reuses ANTHROPIC_API_KEY
# OPENCLAW_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# openclaw-claude-openai  (Claude via OpenAI-compatible proxy)
# OPENCLAW_CLAUDE_OPENAI_API_KEY=your-proxy-api-key
# OPENCLAW_CLAUDE_OPENAI_BASE_URL=https://your-proxy-endpoint/v1

# openclaw-gpt  — reuses OPENAI_API_KEY
# OPENCLAW_OPENAI_BASE_URL=https://api.openai.com/v1

# openclaw-glm  — reuses ZHIPU_API_KEY
# OPENCLAW_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# openclaw-minimax  — reuses MINIMAX_API_KEY
# OPENCLAW_MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Optional OpenClaw directory overrides (have built-in defaults)
# OPENCLAW_CONFIG_DIR=/home/node/.openclaw
# OPENCLAW_WORKSPACE_DIR=/home/node/.openclaw/workspace
# OPENCLAW_WORKDIR=
# CLAUDE_WORKDIR=


# -----------------------------------------------------------------------------
# 4. Sandbox  (OpenSandbox execution environment)
# -----------------------------------------------------------------------------
# All optional — defaults shown. Override to point at a remote sandbox.
# SANDBOX_DOMAIN=localhost:8080
# SANDBOX_API_KEY=
# SANDBOX_IMAGE=claude_code:latest


# -----------------------------------------------------------------------------
# 5. Misc overrides  (optional — usually set in config/main.yaml instead)
# -----------------------------------------------------------------------------
# MAX_CONCURRENCY=2
# COMMAND_TIMEOUT=2400
# MAX_TESTS=
# OUTPUT_DIR=
# EVALUATION_CONFIG_PATH=config/main.yaml
